# Copy to .env (which is gitignored) and fill in real values for deployment.
# In development you can leave most of these unset — settings.py has safe
# localhost defaults — but DJANGO_SECRET_KEY is REQUIRED whenever DEBUG is off.

# ── Django core ──────────────────────────────────────────────────
# Generate: python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Frontend origins allowed to call the API (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Database (PostgreSQL) ────────────────────────────────────────
DB_NAME=signalflow_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# ── Celery / Redis ───────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
DJANGO_CACHE_URL=redis://localhost:6379/2
PREDICTION_CACHE_TTL=21600
